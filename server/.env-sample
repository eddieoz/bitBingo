PORT=5000
NODE_ENV=development

# Pinata API
PINATA_JWT_KEY=your_pinata_jwt_key_here

# Bitcoin blockchain API providers (tried in order)
# Available providers: mempool, blockstream, blockchain_info
BITCOIN_API_ORDER=mempool,blockstream,blockchain_info

# Optional: Override individual provider base URLs
# MEMPOOL_API_BASE=https://mempool.space/api
# BLOCKSTREAM_API_BASE=https://blockstream.info/api
# BLOCKCHAIN_INFO_API_BASE=https://blockchain.info

# Optional: API timeout in milliseconds (default: 10000)
# BITCOIN_API_TIMEOUT=10000

# Optional: Specify the public IPFS gateway for viewing files (defaults to https://gateway.pinata.cloud/ipfs)
# PINATA_PUBLIC_GATEWAY_BASE=https://ipfs.io/ipfs